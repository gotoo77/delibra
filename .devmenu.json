{
  "project": {
    "name": "Delibra",
    "type": "python",
    "lang": "fr",
    "icon": "⚖️",
    "timeout": 900
  },
  "menus": {
    "main": {
      "title": "Delibra",
      "items": [
        {
          "label": "Sync dev",
          "icon": "📦",
          "key": "i",
          "argv": ["uv", "sync"],
          "desc": "Installe l environnement Python depuis pyproject.toml et uv.lock"
        },
        {
          "label": "Installer editable",
          "icon": "🧩",
          "key": "e",
          "argv": ["uv", "pip", "install", "-e", "."],
          "desc": "Installe la commande delibra en editable dans l environnement uv"
        },
        {
          "label": "Tests",
          "icon": "🧪",
          "key": "t",
          "argv": ["uv", "run", "python", "-m", "unittest"]
        },
        {
          "label": "Check complet",
          "icon": "✅",
          "key": "c",
          "commands": [
            ["uv", "run", "python", "-m", "unittest"],
            ["uv", "run", "python", "-m", "compileall", "src", "tests", "spikes"]
          ],
          "desc": "Tests unitaires et compilation Python"
        },
        {
          "label": "CLI",
          "icon": "🖥️",
          "key": "l",
          "submenu": "cli"
        },
        {
          "label": "Spike 0",
          "icon": "🧪",
          "key": "s",
          "argv": ["uv", "run", "python", "spikes/spike_0_artifact_derivation.py"],
          "desc": "Lance le prototype disposable d artifact derivation"
        },
        {
          "label": "Smoke Lot 5",
          "icon": "🧱",
          "key": "m",
          "argv": ["uv", "run", "python", "-m", "delibra.runtime.smoke", "tests/fixtures/rfc_protocol.yaml"],
          "desc": "Cree un run, un artifact, une trace et affiche le JSON"
        },
        {
          "label": "Docs",
          "icon": "📚",
          "key": "o",
          "submenu": "docs"
        },
        {
          "label": "Git branches",
          "icon": "🌿",
          "key": "g",
          "submenu": "auto:git"
        },
        {
          "label": "Clean",
          "icon": "🗑️",
          "key": "n",
          "commands": [
            ["rm", "-rf", "build", "dist", "src/delibra.egg-info"],
            ["bash", "-lc", "find . -name '__pycache__' -type d -prune -exec rm -rf {} + 2>/dev/null || true"],
            ["bash", "-lc", "find . -name '*.pyc' -delete 2>/dev/null || true"]
          ],
          "desc": "Supprime les artefacts de build et caches Python"
        },
        {
          "label": "Historique",
          "icon": "🕘",
          "key": "h",
          "action": "history"
        },
        {
          "label": "Quitter",
          "icon": "🚪",
          "key": "x",
          "action": "exit"
        }
      ]
    },
    "cli": {
      "title": "Delibra - CLI",
      "items": [
        {
          "label": "Aide",
          "icon": "❔",
          "key": "h",
          "argv": ["uv", "run", "delibra", "--help"]
        },
        {
          "label": "Aide validate",
          "icon": "🧭",
          "key": "v",
          "argv": ["uv", "run", "delibra", "validate", "--help"]
        },
        {
          "label": "Aide run",
          "icon": "▶️",
          "key": "r",
          "argv": ["uv", "run", "delibra", "run", "--help"]
        },
        {
          "label": "Validate fixture",
          "icon": "✅",
          "key": "d",
          "argv": ["uv", "run", "delibra", "validate", "--protocol", "tests/fixtures/rfc_protocol.yaml"],
          "desc": "Parse le fixture YAML et affiche le JSON canonique"
        },
        {
          "label": "Run mock fixture",
          "icon": "▶️",
          "key": "u",
          "argv": [
            "uv",
            "run",
            "delibra",
            "run",
            "--protocol",
            "tests/fixtures/prompt_synthesize_protocol.yaml",
            "--input-text",
            "Why protect oceans?",
            "--run-output",
            "/tmp/delibra-run.json",
            "--trace-output",
            "/tmp/delibra-trace.json"
          ],
          "desc": "Execute prompt+synthesize avec le mock et ecrit run/trace dans /tmp"
        },
        {
          "label": "Scenario code review",
          "icon": "🔎",
          "key": "s",
          "argv": ["scripts/run_real_code_review.sh"],
          "desc": "Lance le preset code_review sur un vrai git diff. Produit input.patch, run.json, trace.json, inspect.txt et final_synthesis.txt dans un dossier temporaire affiche en fin de commande"
        },
        {
          "label": "Retour",
          "icon": "↩️",
          "key": "z",
          "submenu": "main"
        }
      ]
    },
    "docs": {
      "title": "Delibra - Docs",
      "items": [
        {
          "label": "README",
          "icon": "📄",
          "key": "r",
          "argv": ["sed", "-n", "1,220p", "README.md"]
        },
        {
          "label": "Philosophie",
          "icon": "⚖️",
          "key": "p",
          "argv": ["sed", "-n", "1,220p", "PHILOSOPHY.md"]
        },
        {
          "label": "Core model",
          "icon": "🧱",
          "key": "m",
          "argv": ["sed", "-n", "1,260p", "docs/core-model-v0.1.md"]
        },
        {
          "label": "Backlog",
          "icon": "📋",
          "key": "b",
          "argv": ["sed", "-n", "1,260p", "docs/implementation/backlog-v0.1.md"]
        },
        {
          "label": "Invariants",
          "icon": "✅",
          "key": "i",
          "argv": ["sed", "-n", "1,220p", "docs/implementation/invariants.md"]
        },
        {
          "label": "Rapport Spike 0",
          "icon": "🧪",
          "key": "s",
          "argv": ["sed", "-n", "1,240p", "docs/implementation/spike-0-report.md"]
        },
        {
          "label": "Retour",
          "icon": "↩️",
          "key": "z",
          "submenu": "main"
        }
      ]
    }
  }
}
